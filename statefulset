apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: my-statefulset

spec:
  serviceName: "my-service"
  replicas: 4

  selector:
    matchLabels:
      app: nginx

  template:
    metadata:
      labels:
        app: nginx

    spec:
      containers:
      - name: nginx
        image: nginx
        ports:
        - containerPort: 80
